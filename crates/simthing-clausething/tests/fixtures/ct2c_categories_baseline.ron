                        role: AllocatorWeight(arena: "settlement_energy"),
                        log_tier: Summary,
                    )),
                ),
            ],
        ),
        PropertySpec(
            id: "simthing_settlement_food_flow",
            namespace: "simthing",
            name: "settlement_food_flow",
