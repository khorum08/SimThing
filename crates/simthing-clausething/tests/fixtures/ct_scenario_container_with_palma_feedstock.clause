scenario = bh3_closeout_pr5_palma {
    metadata = {
        display_name = "BH3 Closeout PR5 PALMA Feedstock Scenario"
        description = "Scenario-contained PALMA W/D feedstock authoring."
    }

    location = alpha {
        name = "Alpha Basin"
    }

    location = beta {
        name = "Beta Shelf"
    }

    link = {
        from = alpha
        to = beta
    }

    field_operator = alpha_choke_flux {
        display_name = "Alpha Choke Flux"
        grid_size = 10
        source_col = 0
        target_col = 0
        n_dims = 6
        alpha_self = 0.5
        gamma_neighbor = 0.125
        horizon = 8

        saturating_flux = {
            u_sat = 1.0
            chi = 0.25
            choke_output_col = 2
        }
    }

    palma_feedstock = alpha_wd {
        w_source = alpha_choke_flux
        w_output_col = 3
        d_output_col = 4
        enabled = false
    }
}
