                    display_range: None,
                    governed_by: None,
                    reduction_override: None,
                ),
            ],
        ),
    ],
    resource_economy: Some(ResourceEconomySpec(
        opt_in_mode: TransferAndEmission,
        transfers: [
            ResourceTransferSpec(
                id: "credits_to_store",
                source: (namespace: "core", name: "credits"),
                source_role: Named("amount"),
                target: (namespace: "core", name: "store"),
                target_role: Named("amount"),
                amount: 1.0,
                order_band: 1,
            ),
        ],
        recipes: [
