                    clamp: Unbounded,
                    velocity_max: None,
                    default: 0.0,
                    display_name: "Amount",
                    display_range: None,
                    governed_by: None,
                    reduction_override: None,
                ),
            ],
        ),
        PropertySpec(
            id: "core_food",
            namespace: "core",
            name: "food",
            display_name: "Food",
            sub_fields: [
                SubFieldSpec(
                    role: Named("amount"),
                    width: 1,
                    clamp: Unbounded,
                    velocity_max: None,
                    default: 5.0,
                    display_name: "Amount",
                    display_range: None,
                    governed_by: None,
                    reduction_override: None,
                ),
            ],
        ),
        PropertySpec(
            id: "core_ore",
            namespace: "core",
            name: "ore",
            display_name: "Ore",
            sub_fields: [
                SubFieldSpec(
                    role: Named("amount"),
                    width: 1,
                    clamp: Unbounded,
                    velocity_max: None,
                    default: 5.0,
                    display_name: "Amount",
                    display_range: None,
                    governed_by: None,
                    reduction_override: None,
                ),
            ],
        ),
        PropertySpec(
            id: "core_goods",
            namespace: "core",
            name: "goods",
            display_name: "Goods",
            sub_fields: [
                SubFieldSpec(
                    role: Named("amount"),
                    width: 1,
                    clamp: Unbounded,
                    velocity_max: None,
                    default: 0.0,
                    display_name: "Amount",
                    display_range: None,
                    governed_by: None,
                    reduction_override: None,
                ),
