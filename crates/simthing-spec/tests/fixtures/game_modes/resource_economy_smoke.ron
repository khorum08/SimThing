    description: "Minimal designer-authored resource economy fixture for RON path coverage.",
    spec_version: (major: 1, minor: 0, patch: 0),
    properties: [
        PropertySpec(
            id: "core_credits",
            namespace: "core",
            name: "credits",
            display_name: "Credits",
            sub_fields: [
                SubFieldSpec(
