GameModeSpec(
    id: "phase_m_daily_economy_banking_deficit",
    display_name: "Phase M Daily Economy Banking Deficit",
    description: "Deficit variant: upkeep exceeds income; low treasury threshold emits via existing EmitOnThreshold substrate.",
    spec_version: (major: 1, minor: 0, patch: 0),
    properties: [
        PropertySpec(
            id: "core_treasury",
            namespace: "core",
            name: "treasury",
            display_name: "Treasury",
            sub_fields: [
                SubFieldSpec(
                    role: Named("amount"),
                    width: 1,
                    clamp: Unbounded,
                    velocity_max: None,
                    default: 100.0,
                    display_name: "Amount",
                    display_range: None,
                    governed_by: None,
                    reduction_override: None,
                ),
            ],
        ),
        PropertySpec(
            id: "core_producer",
            namespace: "core",
            name: "producer",
            display_name: "Producer",
            sub_fields: [
                SubFieldSpec(
                    role: Named("amount"),
                    width: 1,
                    clamp: Unbounded,
                    velocity_max: None,
                    default: 2.0,
                    display_name: "Amount",
                    display_range: None,
                    governed_by: None,
                    reduction_override: None,
                ),
            ],
        ),
        PropertySpec(
            id: "core_upkeep_sink",
            namespace: "core",
            name: "upkeep_sink",
            display_name: "Upkeep Sink",
            sub_fields: [
                SubFieldSpec(
                    role: Named("amount"),
                    width: 1,
                    clamp: Unbounded,
                    velocity_max: None,
                    default: 0.0,
                    display_name: "Amount",
                    display_range: None,
                    governed_by: None,
                    reduction_override: None,
                ),
            ],
        ),
    ],
    resource_economy: Some(ResourceEconomySpec(
        opt_in_mode: TransferOnly,
        transfers: [
            ResourceTransferSpec(
                id: "bank_daily_income",
                source: (namespace: "core", name: "producer"),
                source_role: Named("amount"),
                target: (namespace: "core", name: "treasury"),
                target_role: Named("amount"),
                amount: 2.0,
                order_band: 0,
            ),
            ResourceTransferSpec(
                id: "daily_upkeep",
                source: (namespace: "core", name: "treasury"),
                source_role: Named("amount"),
                target: (namespace: "core", name: "upkeep_sink"),
                target_role: Named("amount"),
                amount: 8.0,
                order_band: 1,
            ),
        ],
        emit_on_threshold: [
            EmitOnThresholdSpec(
                id: "low_storage_event",
                source: (namespace: "core", name: "treasury"),
                source_role: Named("amount"),
                threshold: 95.0,
                direction: Falling,
                event_kind: 0x4C4F5754,
                buffer: Values,
            ),
        ],
    )),
)
