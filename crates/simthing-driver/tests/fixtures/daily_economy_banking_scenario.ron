GameModeSpec(
    id: "phase_m_daily_economy_banking",
    display_name: "Phase M Daily Economy Banking",
    description: "Example boundary banking fixture: host interprets ticks_per_day=1 as one day via discrete resource economy transfers/recipes.",
    spec_version: (major: 1, minor: 0, patch: 0),
    properties: [
        PropertySpec(
            id: "core_treasury",
            namespace: "core",
            name: "treasury",
            display_name: "Treasury",
            sub_fields: [
                SubFieldSpec(
                    role: Named("amount"),
                    width: 1,
                    clamp: Unbounded,
                    velocity_max: None,
                    default: 100.0,
                    display_name: "Amount",
                    display_range: None,
                    governed_by: None,
                    reduction_override: None,
                ),
            ],
        ),
        PropertySpec(
            id: "core_producer",
            namespace: "core",
            name: "producer",
            display_name: "Producer",
            sub_fields: [
                SubFieldSpec(
                    role: Named("amount"),
                    width: 1,
                    clamp: Unbounded,
                    velocity_max: None,
                    default: 10.0,
                    display_name: "Amount",
                    display_range: None,
                    governed_by: None,
                    reduction_override: None,
                ),
            ],
        ),
        PropertySpec(
            id: "core_food",
            namespace: "core",
            name: "food",
            display_name: "Food",
            sub_fields: [
                SubFieldSpec(
                    role: Named("amount"),
                    width: 1,
                    clamp: Unbounded,
                    velocity_max: None,
                    default: 60.0,
                    display_name: "Amount",
                    display_range: None,
                    governed_by: None,
                    reduction_override: None,
                ),
            ],
        ),
        PropertySpec(
            id: "core_ore",
            namespace: "core",
            name: "ore",
            display_name: "Ore",
            sub_fields: [
                SubFieldSpec(
                    role: Named("amount"),
                    width: 1,
                    clamp: Unbounded,
                    velocity_max: None,
                    default: 60.0,
                    display_name: "Amount",
                    display_range: None,
                    governed_by: None,
                    reduction_override: None,
                ),
            ],
        ),
        PropertySpec(
            id: "core_upkeep_sink",
            namespace: "core",
            name: "upkeep_sink",
            display_name: "Upkeep Sink",
            sub_fields: [
                SubFieldSpec(
                    role: Named("amount"),
                    width: 1,
                    clamp: Unbounded,
                    velocity_max: None,
                    default: 0.0,
                    display_name: "Amount",
                    display_range: None,
                    governed_by: None,
                    reduction_override: None,
                ),
            ],
        ),
    ],
    resource_economy: Some(ResourceEconomySpec(
        opt_in_mode: TransferOnly,
        transfers: [
            ResourceTransferSpec(
                id: "bank_daily_income",
                source: (namespace: "core", name: "producer"),
                source_role: Named("amount"),
                target: (namespace: "core", name: "treasury"),
                target_role: Named("amount"),
                amount: 10.0,
                order_band: 0,
            ),
            ResourceTransferSpec(
                id: "daily_upkeep",
                source: (namespace: "core", name: "treasury"),
                source_role: Named("amount"),
                target: (namespace: "core", name: "upkeep_sink"),
                target_role: Named("amount"),
                amount: 3.0,
                order_band: 1,
            ),
        ],
        recipes: [
            ResourceRecipeSpec(
                id: "daily_income",
                inputs: [
                    RecipeInputSpec(
                        property: (namespace: "core", name: "food"),
                        role: Named("amount"),
                        unit_cost: 1.0,
                    ),
                    RecipeInputSpec(
                        property: (namespace: "core", name: "ore"),
                        role: Named("amount"),
                        unit_cost: 1.0,
                    ),
                ],
                target: (namespace: "core", name: "producer"),
                target_role: Named("amount"),
                output_coefficient: 1.0,
                order_band: 0,
                throttle_hint_max_per_tick: 10,
            ),
        ],
    )),
)
