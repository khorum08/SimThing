# TP-FULL-TRANSPILE-0 â€” complete Terran-Pirate scenario as a single native ClauseScript file.
# Portable operator payload: source_json is a sibling relative path (clause-directory resolution; empty resolver).
scenario = terran_pirate_galaxy {
    metadata = {
        display_name = "Terran-Pirate Galaxy"
        runtime_owner = "scenario-container"
        description = "0.0.8.5 full-scenario native ClauseScript ingestion vertical"
        # Mechanism-B workshop surfaces (diplomacy RF, live MF execution, fleet movement)
        # remain post-hydration consumers of this transpile; declared here as authoring
        # posture for TP-LIVE-RUN-0 without embedding workshop semantics in clausething.
        diplomacy_lane_profile = "influence_distrust_rf"
        fleet_movement_profile = "palma_d_gradient_reparent"
        fronts_profile = "threat_suppression_disruption_l1_l3"
    }

    static_galaxy_scenario = base_disc {
        namespace = "tp_base"
        source_json = "terran_pirate_galaxy.base_disc.json"
        map_quality_status = PASS
    }

    owner = terran {
        owner_key = "terran"
        display_name = "Terran Compact"
        faction_name = "Terran"
        color_rgb = "64,160,255"
        faction_alliance = "none"
        archetype = "settler_policy"
        personality_profile = "terran_reinforce"
        capability_profile = "patrol_suppression"
    }
    owner = pirate {
        owner_key = "pirate"
        display_name = "Pirate Cartel"
        faction_name = "Pirate"
        color_rgb = "220,64,48"
        faction_alliance = "none"
        archetype = "raider_policy"
        personality_profile = "pirate_raid"
        capability_profile = "raid_disruption"
    }

    # Field-economy STEAD locations (12.6 grammar): explicit Location participants
    # with structural placements. Base disc remains the galaxy lattice; these enroll
    # production/disruption fields without hand-editing sibling JSON.
    location = terran_shipyard {
        display_name = "Terran Shipyard"
        ownership_volume = "terran_core"
    }
    location = pirate_outpost {
        display_name = "Pirate Outpost"
        ownership_volume = "pirate_border"
    }

    ownership_volume = terran_core {
        owner = "terran"
        count = 200
        selection = chebyshev_contiguous
        seed = 770421
        anchor_row = 199
        anchor_col = 80
    }
    ownership_volume = pirate_border {
        owner = "pirate"
        count = 50
        selection = chebyshev_contiguous
        adjacent_to = "terran_core"
        seed = 770421
    }

    planet_surface_payload = owned_system_payload {
        applies_to = owned_systems
        planets_per_system_min = 1
        surface_grid = "1x1"
        factory_min = 1
        cohort_min = 1
        category_map = {
            pop_factory = { kind = Cohort depth = 3 }
        }
        resource = {
            id = "tp_minerals"
            namespace = "tp"
            name = "minerals"
            display_name = "Minerals"
        }
        modifier = {
            pop_factory_minerals_produces_mult = 0.10
            pop_factory_minerals_upkeep_add = 1
        }
    }
    planet_surface_payload = neutral_system_payload {
        applies_to = neutral_systems
        planets_per_system_min = 1
        surface_grid = "1x1"
        factory_min = 0
        cohort_min = 0
    }

    fleet_ship_payload = terran_fleets {
        owner = "terran"
        ownership_volume = "terran_core"
        enemy_ownership_volume = "pirate_border"
        fleet_count = 10
        ships_per_fleet = 20
        border_fleet_count = 6
        ship_class = "corvette"
        hull_seed = 100
        weapon_damage_seed = 25
        upkeep_per_ship = 2
        resource = {
            id = "tp_energy"
            namespace = "tp"
            name = "energy"
            display_name = "Energy"
        }
    }
    fleet_ship_payload = pirate_fleets {
        owner = "pirate"
        ownership_volume = "pirate_border"
        enemy_ownership_volume = "terran_core"
        fleet_count = 10
        ships_per_fleet = 40
        border_fleet_count = 8
        ship_class = "corvette"
        hull_seed = 80
        weapon_damage_seed = 30
        upkeep_per_ship = 3
        resource = {
            id = "tp_energy"
            namespace = "tp"
            name = "energy"
            display_name = "Energy"
        }
    }

    # 12.8/12.10 — canonical TP field economy (generic grammar only; DATA, not code).
    # Terran: minerals field -> shipyard factory -> hulls (ship-construction need).
    # Pirate: disruption emitters + authored local-flow coupling + disruption-need profile.
    # Owner policy overlays are the paired weight axis for 12.10 OVL divergence.
    # Production output coefficients consume HORIZON-ENTRY(2026-07-16).
    field_economy = tp_economy {
        namespace = "tp_economy"
        field_resource_quantity = shipyard_minerals {
            location = "terran_shipyard"
            resource = "minerals"
            amount = 100
        }
        production_building = shipyard_factory {
            location = "terran_shipyard"
            input = { resource = "minerals" amount = 5 }
            output = { resource = "hulls" coefficient = 2.0 }
            throttle_hint_max_per_tick = 4
        }
        stockpile_silo = terran_minerals {
            owner = "terran"
            resource = "minerals"
            current = 40
        }
        stockpile_silo = terran_expansion_weight {
            owner = "terran"
            resource = "expansion_weight"
            current = 0.02
        }
        stockpile_silo = pirate_disruption_weight {
            owner = "pirate"
            resource = "disruption_weight"
            current = 2
        }
        disruption_presence = pirate_raid_presence {
            location = "pirate_outpost"
            resource = "disruption"
            amount = 8
            threshold = 3
            direction = Rising
            event_kind = 71
        }
        flow_coupling = pirate_raid_suppresses_shipyard {
            source = { location = "terran_shipyard" resource = "hulls" unit_cost = 1.0 }
            pressure = { location = "pirate_outpost" resource = "disruption" unit_cost = 1.0 }
            weight = { owner = "pirate" resource = "disruption_weight" unit_cost = 1.0 }
            sink = { location = "terran_shipyard" resource = "disrupted_hulls" }
            output_coefficient = 1.0
            order_band = 3
        }
        owner_policy_overlay = terran_expansion_policy {
            owner = "terran"
            targets_property = "tp_economy::terran_shipyard_hulls_quantity"
            amount_mult = 1.15
        }
        owner_policy_overlay = terran_manufacturing_policy {
            owner = "terran"
            targets_property = "tp_economy::terran_shipyard_hulls_quantity"
            amount_add = 0.25
        }
        owner_policy_overlay = pirate_disruption_policy {
            owner = "pirate"
            targets_property = "tp_economy::pirate_outpost_disruption_presence"
            amount_mult = 1.35
        }
        weight_profile = terran_expansion_need {
            profile = "expansion-need"
            input = { input_col = 0 weight_col = 10 }
            output_col = 12
        }
        weight_profile = terran_manufacturing_need {
            profile = "manufacturing-need"
            input = { input_col = 2 weight_col = 13 }
            output_col = 14
        }
        # 12.10 construction need: sealed crossings from produced hulls (not RF-5 minerals).
        # RF-5 expansion/minerals regressions keep event_kind 91 via test source variants.
        need_binding = terran_manufacturing_need {
            profile = "manufacturing-need"
            participant = "terran"
            arena = "studio_recursive_owner_flow"
            input = {
                entity = "terran_shipyard"
                property = "tp_economy::terran_shipyard_hulls_quantity"
                role = Amount
            }
            weight = {
                entity = "terran"
                property = "tp_economy::terran_expansion_weight_stockpile"
                role = Amount
            }
            # Above RF-5's minerals threshold (1.0): high weight crosses from hull
            # accretion; low-weight paired authoring stays below.
            threshold = 5.0
            event_kind = 92
        }
        weight_profile = pirate_disruption_need {
            profile = "disruption-need"
            input = { input_col = 3 weight_col = 15 }
            output_col = 16
        }
    }

    combat_arena_payload = contact_arena {
        system_target = "row199_col80"
        hull_capacity = 100
        hp_recovery_per_tick = 0
        ships_per_side = 1
        terran_weapon_damage = 25
        pirate_weapon_damage = 30
    }

    # Movement-Front L1 feedstock (SaturatingFlux) â€” bounded theater grid for STEAD
    # authoring; full-galaxy dense MF remains atlas Deviation for TP-LIVE-RUN-0.
    field_operator = contested_border_flux {
        display_name = "Contested Border SaturatingFlux"
        grid_size = 16
        source_col = 0
        target_col = 0
        n_dims = 6
        alpha_self = 0.5
        gamma_neighbor = 0.125
        horizon = 3

        saturating_flux = {
            u_sat = 1.0
            chi = 0.25
            choke_output_col = 2
        }
    }

    # PALMA W/D reach/impedance feedstock over the border field.
    palma_feedstock = border_reach {
        w_source = contested_border_flux
        w_output_col = 3
        d_output_col = 4
        enabled = false
    }

    # FIELD_POLICY commitment feedstock (ai_will_do urgency over L3 pressure column).
    # Default-off; live threshold fire belongs to TP-LIVE-RUN-0 / TP-COMMITMENTS path.
    commitment = frontier_commitment {
        threshold = 0.75
        event_kind = 7
        field_urgency = {
            source = contested_border_flux
            column = 2
            weight = 1.0
            weight_pressure = 1.0
            weight_resource = 0.25
        }
    }
}
